NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Canonical public URL (production domain). Used for Supabase auth redirectTo from the server.
# Add this exact URL under Supabase Auth → Redirect URLs: https://plenvoapp.com/auth/callback
NEXT_PUBLIC_SITE_URL=https://plenvoapp.com

# Server-only: لوحة الإدارة (دمج auth.users + profiles) — لا تُعرّض هذا المفتاح للمتصفح
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Office 365 SMTP (support form → support@plenvoapp.com)
EMAIL_USER=your_office365_email@yourdomain.com
EMAIL_PASS=your_app_password_or_account_password
